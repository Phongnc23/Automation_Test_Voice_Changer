<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Voice Changer Regression Suite" verbose="1">

    <listeners>
        <listener class-name="Listeners.TestListener"/>
    </listeners>

    <test name="Home Tests">
        <classes>
            <class name="testcases.Home.Home01_Verify_App_Launched"/>
            <class name="testcases.Home.Home02_Verify_UI_Display"/>
            <class name="testcases.Home.Home03_Verify_Navigation"/>
            <class name="testcases.Home.Home04_Verify_Edge_Cases"/>
        </classes>
    </test>

    <test name="Record Tests">
        <classes>
            <class name="testcases.Record.Record01_Verify_UI_Display"/>
            <class name="testcases.Record.Record02_Verify_Recording_Actions"/>
            <class name="testcases.Record.Record03_Verify_Close_Cancel"/>
        </classes>
    </test>

    <test name="Voice Effects Tests">
        <classes>
            <class name="testcases.Voiceeffects.VoiceEffects01_Verify_UI_Display"/>
            <class name="testcases.Voiceeffects.VoiceEffects02_Verify_Audio_Player"/>
            <class name="testcases.Voiceeffects.VoiceEffects03_Verify_Apply_Effects"/>
            <class name="testcases.Voiceeffects.VoiceEffects04_Verify_Save_Close"/>
            <class name="testcases.Voiceeffects.VoiceEffects05_Verify_Send_Voice_Message"/>
        </classes>
    </test>

    <test name="Audio Saved Tests">
        <classes>
            <class name="testcases.Audiosaved.AudioSaved01_Verify_UI_Display"/>
            <class name="testcases.Audiosaved.AudioSaved02_Verify_Navigation_Share"/>
            <class name="testcases.Audiosaved.AudioSaved03_Verify_Rename"/>
            <class name="testcases.Audiosaved.AudioSaved04_Verify_Open_With"/>
        </classes>
    </test>

    <test name="Ringtone Tests">
        <classes>
            <class name="testcases.Ringtone.Ringtone01_Verify_Set_Ringtone"/>
        </classes>
    </test>

    <test name="Text to Speech Tests">
        <classes>
            <class name="testcases.TextToSpeech.TextToAudio01_Verify_UI_Display"/>
            <class name="testcases.TextToSpeech.TextToAudio02_Verify_Language_Selection"/>
            <class name="testcases.TextToSpeech.TextToAudio03_Verify_Text_Input"/>
            <class name="testcases.TextToSpeech.TextToAudio04_Verify_TTS_File_Name"/>
        </classes>
    </test>

    <test name="My Audio Tests">
        <classes>
            <class name="testcases.MyAudio.MyAudio01_Verify_UI_Display"/>
            <class name="testcases.MyAudio.MyAudio02_Verify_Search"/>
            <class name="testcases.MyAudio.MyAudio03_Verify_Edit_Menu"/>
            <class name="testcases.MyAudio.MyAudio04_Verify_Rename"/>
            <class name="testcases.MyAudio.MyAudio05_Verify_Delete"/>
            <class name="testcases.MyAudio.MyAudio06_Verify_Open_File_Save_Flow"/>
            <class name="testcases.MyAudio.MyAudio07_Verify_Send_Voice_Message_From_Edit_Menu"/>
            <class name="testcases.MyAudio.MyAudio08_Verify_Share_From_Edit_Menu"/>
        </classes>
    </test>

    <test name="Import Audio Tests">
        <classes>
            <class name="testcases.ImportAudio.ImportAudio01_Verify_File_Picker"/>
            <class name="testcases.ImportAudio.ImportAudio02_Verify_Select_File"/>
            <class name="testcases.ImportAudio.ImportAudio03_Verify_File_Name"/>
        </classes>
    </test>

    <test name="Drawer Menu Tests">
        <classes>
            <class name="testcases.DrawerMenu.DrawerMenu01_Verify_UI_Display"/>
            <class name="testcases.DrawerMenu.DrawerMenu02_Verify_Privacy_Policy"/>
            <class name="testcases.DrawerMenu.DrawerMenu03_Verify_Rate_Us"/>
            <class name="testcases.DrawerMenu.DrawerMenu04_Verify_Share_App"/>
            <class name="testcases.DrawerMenu.DrawerMenu05_Verify_Feedback"/>
            <class name="testcases.DrawerMenu.DrawerMenu06_Verify_Version_Exit"/>
        </classes>
    </test>

    <test name="Settings Tests" preserve-order="true">
        <classes>
            <class name="testcases.Setting.Setting01_Verify_UI_Display"/>
            <class name="testcases.Setting.Setting02_Verify_Output_Path"/>
            <class name="testcases.Setting.Setting03_Verify_Language"/>
            <class name="testcases.Setting.Setting04_Verify_Version"/>
        </classes>
    </test>

</suite>